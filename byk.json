{
  "$var": {
    "url":"https://github.com/fcbyk/pyodd/releases/download/pkg"
  },

  "ai": {
    "pip": [
      "aichat @ {url}/aichat-0.1.0-py3-none-any.whl"
    ],

    "command": {
      "type": "py-module",
      "entry": "aichat",
      "desc": "在终端和AI聊天"
    }
  },

  "jiahao": {
    "pip-keep": ["click", "rich"],
    "scripts": {
      "jiahao.py":"scripts/jiahao.py"
    },
    "command": {
      "type": "py-script",
      "entry": "jiahao.py",
      "desc": "zhuang x commands"
    }
  },

  "popup": {
    "pip-keep": ["click"],
    "scripts": {
      "popup.py":"scripts/popup.py"
    },
    "command": {
      "type": "py-script",
      "entry": "popup.py",
      "desc": "Display multiple popup windows"
    }
  }
}
